{
  "name": "task-manager-be",
  "version": "1.0.0",
  "private": true,
  "description": "TaskManager API — Node.js backend for task management",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:test-aurora": "node scripts/test-aurora-iam.js",
    "db:create-app-db": "node scripts/create-taskmanager-db-password.js",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "graphql": "^16.10.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "@aws-sdk/rds-signer": "^3.758.0",
    "pg": "^8.14.1",
    "prisma": "^6.5.0"
  }
}
