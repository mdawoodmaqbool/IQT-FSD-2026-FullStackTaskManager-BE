```
src/services/externalApiService.js   # Core integration logic
src/controllers/externalController.js
src/routes/external.js
src/middleware/rateLimit.js          # externalRateLimiter
prisma/schema.prisma                 # countryCode, countryName on User
prisma/migrations/.../user_country/
```

